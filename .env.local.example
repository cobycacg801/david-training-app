# ─────────────────────────────────────────────
# EMAIL  (Resend — https://resend.com)
# ─────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The "from" address shown on all outgoing emails.
# Must be a verified domain in your Resend account.
EMAIL_FROM=David Training <noreply@yourdomain.com>

# David's real email — receives booking requests, cancellation alerts, etc.
DAVID_EMAIL=david@yourdomain.com

# ─────────────────────────────────────────────
# SMS  (Twilio — https://twilio.com/console)
# ─────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here

# The Twilio phone number that sends the SMS (must be in E.164 format).
# Buy a number in Twilio Console → Phone Numbers → Manage → Buy a Number
TWILIO_FROM=+17135550000

# David's personal phone number (receives new booking alerts & member cancellations).
DAVID_PHONE=+17135550001

# ─────────────────────────────────────────────
# CRON  (Vercel Cron — 24h reminder job)
# ─────────────────────────────────────────────
# Generate a strong random secret, e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Add this same value to Vercel → Settings → Environment Variables.
CRON_SECRET=your_random_cron_secret_here

